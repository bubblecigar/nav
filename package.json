{
  "name": "nav-extension",
  "displayName": "Navigation Extension",
  "description": "A VS Code extension for enhanced navigation",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:nav-extension.helloWorld",
    "onCommand:nav-extension.bookmarkWord",
    "onCommand:nav-extension.showBookmarkHistory",
    "onCommand:nav-extension.clearBookmarkHistory"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "nav-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "nav-extension.bookmarkWord",
        "title": "Bookmark Word/Selection"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "title": "Show Bookmark History"
      },
      {
        "command": "nav-extension.clearBookmarkHistory",
        "title": "Clear Bookmark History"
      }
    ],
    "keybindings": [
      {
        "command": "nav-extension.bookmarkWord",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}