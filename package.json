{
  "name": "nav-extension",
  "displayName": "Navigation Extension",
  "description": "A VS Code extension for enhanced navigation",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bookmark-explorer",
          "title": "Bookmarks",
          "icon": "$(bookmark)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "bookmarkExplorer",
          "name": "Bookmark History",
          "when": "true",
          "icon": "$(bookmark)"
        },
        {
          "id": "bookmarkDetailsView",
          "name": "Bookmark Details",
          "when": "true",
          "type": "webview"
        }
      ]
    },
    "commands": [
      {
        "command": "nav-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "nav-extension.bookmarkWord",
        "title": "Bookmark Word/Selection",
        "icon": "$(add)"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "title": "Show Bookmark History",
        "icon": "$(list-unordered)"
      },
      {
        "command": "nav-extension.navigateToBookmark",
        "title": "Go to Line",
        "icon": "$(go-to-file)"
      },
      {
        "command": "nav-extension.clearBookmarkHistory",
        "title": "Clear All Bookmarks",
        "icon": "$(clear-all)"
      },
      {
        "command": "nav-extension.removeBookmark",
        "title": "Remove Bookmark",
        "icon": "$(close)"
      },
      {
        "command": "nav-extension.focusBookmarkExplorer",
        "title": "Focus Bookmark Explorer",
        "icon": "$(search-view-icon)"
      },
      {
        "command": "nav-extension.moveBookmarkUp",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "nav-extension.moveBookmarkDown",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      },
      {
        "command": "nav-extension.expandAllBookmarks",
        "title": "Expand All",
        "icon": "$(expand-all)"
      },
      {
        "command": "nav-extension.exportBookmarks",
        "title": "Export Bookmarks",
        "icon": "$(export)"
      },
      {
        "command": "nav-extension.importBookmarks",
        "title": "Import Bookmarks",
        "icon": "$(import)"
      },
      {
        "command": "nav-extension.drawDiagram",
        "title": "Draw Diagram",
        "icon": "$(type-hierarchy)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nav-extension.bookmarkWord",
          "when": "view == bookmarkExplorer",
          "group": "navigation@1"
        },
        {
          "command": "nav-extension.expandAllBookmarks",
          "when": "view == bookmarkExplorer",
          "group": "navigation@2"
        },
        {
          "command": "nav-extension.exportBookmarks",
          "when": "view == bookmarkExplorer",
          "group": "io@1"
        },
        {
          "command": "nav-extension.importBookmarks",
          "when": "view == bookmarkExplorer",
          "group": "io@2"        },
        {
          "command": "nav-extension.drawDiagram",
          "when": "view == bookmarkExplorer",
          "group": "visualization@1"        },
        {
          "command": "nav-extension.clearBookmarkHistory",
          "when": "view == bookmarkExplorer",
          "group": "io@3"
        }
      ],
      "view/item/context": [
        {
          "command": "nav-extension.navigateToBookmark",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "inline@2"
        },
        {
          "command": "nav-extension.moveBookmarkUp",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent) && nav-extension.canMoveUp",
          "group": "reorder@1"
        },
        {
          "command": "nav-extension.moveBookmarkDown",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent) && nav-extension.canMoveDown",
          "group": "reorder@2"
        },
        {
          "command": "nav-extension.removeBookmark",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "actions@1"
        }
      ],
      "commandPalette": [
        {
          "command": "nav-extension.removeBookmark",
          "when": "false"
        },
        {
          "command": "nav-extension.moveBookmarkUp",
          "when": "false"
        },
        {
          "command": "nav-extension.moveBookmarkDown",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nav-extension.bookmarkWord",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "nav-extension.focusBookmarkExplorer",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "nav-extension.moveBookmarkUp",
        "key": "ctrl+up",
        "mac": "cmd+up",
        "when": "focusedView == bookmarkExplorer && nav-extension.canMoveUp"
      },
      {
        "command": "nav-extension.moveBookmarkDown",
        "key": "ctrl+down",
        "mac": "cmd+down",
        "when": "focusedView == bookmarkExplorer && nav-extension.canMoveDown"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}