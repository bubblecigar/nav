{
  "name": "nav-extension",
  "displayName": "Navigation Extension",
  "description": "A VS Code extension for enhanced navigation",
  "version": "0.0.1",
  "publisher": "local-dev",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "bookmark-explorer",
          "title": "Bookmarks",
          "icon": "$(bookmark)"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "bookmarkExplorer",
          "name": "Bookmark History",
          "when": "true",
          "icon": "$(bookmark)"
        }
      ]
    },
    "commands": [
      {
        "command": "nav-extension.helloWorld",
        "title": "Hello World"
      },
      {
        "command": "nav-extension.bookmarkWord",
        "title": "Bookmark Word/Selection",
        "icon": "$(add)"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "title": "Show Bookmark History",
        "icon": "$(list-unordered)"
      },
      {
        "command": "nav-extension.clearBookmarkHistory",
        "title": "Clear All Bookmarks",
        "icon": "$(clear-all)"
      },
      {
        "command": "nav-extension.removeBookmark",
        "title": "Remove Bookmark",
        "icon": "$(close)"
      },
      {
        "command": "nav-extension.refreshBookmarkTree",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "nav-extension.focusBookmarkExplorer",
        "title": "Focus Bookmark Explorer",
        "icon": "$(search-view-icon)"
      },
      {
        "command": "nav-extension.setAsParent",
        "title": "Set as Parent",
        "icon": "$(folder)"
      },
      {
        "command": "nav-extension.addChildBookmark",
        "title": "Add Child Bookmark",
        "icon": "$(add)"
      },
      {
        "command": "nav-extension.moveBookmarkUp",
        "title": "Move Up",
        "icon": "$(arrow-up)"
      },
      {
        "command": "nav-extension.moveBookmarkDown",
        "title": "Move Down",
        "icon": "$(arrow-down)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "nav-extension.bookmarkWord",
          "when": "view == bookmarkExplorer",
          "group": "navigation@1"
        },
        {
          "command": "nav-extension.refreshBookmarkTree",
          "when": "view == bookmarkExplorer",
          "group": "navigation@2"
        },
        {
          "command": "nav-extension.clearBookmarkHistory",
          "when": "view == bookmarkExplorer",
          "group": "navigation@3"
        }
      ],
      "view/item/context": [
        {
          "command": "nav-extension.removeBookmark",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "inline"
        },
        {
          "command": "nav-extension.moveBookmarkUp",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "reorder@1"
        },
        {
          "command": "nav-extension.moveBookmarkDown",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "reorder@2"
        },
        {
          "command": "nav-extension.setAsParent",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "bookmark@1"
        },
        {
          "command": "nav-extension.addChildBookmark",
          "when": "view == bookmarkExplorer && (viewItem == bookmarkItem || viewItem == bookmarkParent)",
          "group": "bookmark@2"
        }
      ],
      "commandPalette": [
        {
          "command": "nav-extension.removeBookmark",
          "when": "false"
        },
        {
          "command": "nav-extension.setAsParent",
          "when": "false"
        },
        {
          "command": "nav-extension.addChildBookmark",
          "when": "false"
        },
        {
          "command": "nav-extension.moveBookmarkUp",
          "when": "false"
        },
        {
          "command": "nav-extension.moveBookmarkDown",
          "when": "false"
        }
      ]
    },
    "keybindings": [
      {
        "command": "nav-extension.bookmarkWord",
        "key": "ctrl+shift+b",
        "mac": "cmd+shift+b",
        "when": "editorTextFocus"
      },
      {
        "command": "nav-extension.showBookmarkHistory",
        "key": "ctrl+shift+h",
        "mac": "cmd+shift+h"
      },
      {
        "command": "nav-extension.focusBookmarkExplorer",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.60.0",
    "@types/node": "16.x",
    "typescript": "^4.9.4"
  }
}